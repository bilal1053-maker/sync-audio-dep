extends layout.pug

block vars
	- var applyNoContentStyles = true
block content
	div(style="margin-top:30px; margin-bottom:3%; margin-left:100px; margin-right:10px")#flex_wrapper
		div.flex-container
			div
				h1(style="font-size: 52px; line-height: 60px; font-weight: bold; letter-spacing: -0.025em;")#about_title We’re changing the way people listen to music
				p(style="font-size: 16px; line-height: 32px; color: #4B5563;") Sync-Audio’s team represents the finest music from emerging unsigned, Independent creators.
				p(style="font-size: 16px; line-height: 32px; color: #4B5563;") Our platform was built on discovery where creative filmmakers can find fresh original songs/tracks for their project. We supply quality that’s accessible, affordable, without copyright issues.
				h1(style="font-size: 30px; line-height: 36px; font-weight: bold; letter-spacing: -0.025em; padding-top: 20px;") Our Mission
				p(style="font-size: 16px; line-height: 32px; color: #4B5563;") Sync-Audio was launched by music industry veteran Tesley Francis (alias T J Phillips, producer, writer, musician). His own experience taught him the importance of protecting his content and maintaining an artistic independence.
				p(style="font-size: 16px; line-height: 32px; color: #4B5563;") At Sync-Audio we are passionate about music and its crucial role in our lives. Every day, thousands of unsigned creators upload music online, but too often their voices are lost in the noise - or worse, their IP goes unprotected.
				p(style="font-size: 16px; line-height: 32px; color: #4B5563;") Now that synthetic music is on the rise there is a demand for authenticity, real voices, real emotions and its growing stronger. Our goal is to provide a fair revenue platform for independent artists and outstanding content to our clients.
				div(style="")
					span(style="font-weight:bold;") You own it (joinly), License it! &nbsp;
					span for Films, new media and more...
			div(style= "margin-top:20%")#img_wrapper.align-self-start.flex-center
				div.img-container.flex-1
					img.responsive-img(loading="lazy" ,style="width: 100%; max-width: 600px; aspect-ratio: 2/3; border-radius: 12px; background-color: white; object-fit: cover; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);"
						src="https://images.unsplash.com/photo-1493225457124-a3eb161ffa5f?q=80&w=2070&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D",
						alt="", class="about-img1"
					)
			div(style= "margin-top:10%").mt-0.align-self-start.d-flex-mob.gap-20
				div.img-container
					img.responsive-img(loading="lazy" ,style="width: 100%; max-width: 600px; aspect-ratio: 2/3; border-radius: 12px; background-color: white; object-fit: cover; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);" 
					src="https://images.unsplash.com/photo-1526394931762-90052e97b376?q=80&w=3774&auto=format&fit=crop&ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D" 
					alt="")

