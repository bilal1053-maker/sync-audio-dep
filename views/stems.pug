extends layout.pug

block content
	h1 Upload Stems
	h2 #{track.title}
		span(style="font-weight:normal; font-size:16px; margin-left:10px; color:gray") by #{track.artist}

	if saved
		p(style="color:green; font-weight:bold") Stems saved successfully.

	p(style="color:gray; font-size:14px") Upload stems for this track. Each stem type is optional. Uploading again replaces the existing file.

	form(action="/account/stems/"+track.id, method="post", enctype="multipart/form-data")
		for stemType in stemTypes
			p
				label(style="display:inline-block; width:160px; font-weight:bold") #{stemType}
				if uploadedTypes.includes(stemType)
					span(style="color:green; font-size:12px; margin-right:10px") ✓ uploaded
				input(type="file", name=stemType, accept="audio/wav,audio/mpeg")
		p
			input(type="submit", value="Save Stems")

	p
		a(href="/account/submissions") ← Back to my submissions
