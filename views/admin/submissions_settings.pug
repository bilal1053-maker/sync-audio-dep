extends layout.pug

block scripts
	style.
		.submissions-row { display: flex; align-items: center; gap: 10px; }
		.toggle-switch { position: relative; display: inline-block; width: 38px; height: 20px; flex-shrink: 0; }
		.toggle-switch input { opacity: 0; width: 0; height: 0; }
		.toggle-slider { position: absolute; cursor: pointer; top: 0; left: 0; right: 0; bottom: 0; background-color: #e0e0e0; transition: .2s; border-radius: 20px; }
		.toggle-slider:before { position: absolute; content: ""; height: 14px; width: 14px; left: 3px; bottom: 3px; background-color: white; transition: .2s; border-radius: 50%; }
		.toggle-switch input:checked + .toggle-slider { background-color: rgba(0,150,228,1); }
		.toggle-switch input:checked + .toggle-slider:before { transform: translateX(18px); }
		.toggle-label { font-family: sans-serif; font-size: 18px; color: gray; }

append content
	h1 Submission Settings
	p(style="font-family:sans-serif; font-size:16px; color:#555") Control whether artists can currently submit new tracks to Sync-Audio.
	div.submissions-row
		span.toggle-label= "Submissions: " + (submissionsOpen ? "ON" : "OFF")
		label.toggle-switch
			input(type="checkbox", checked=submissionsOpen, onchange="window.location='/admin/submissions/toggle'")
			span.toggle-slider
