    script.
        $(document).ready(function() {
            $("#categoryFormModal").hide();
            $("#contactModal").hide();

            function disableSubmitButton() {
                $("#form input[type='submit']").prop('disabled', true).css({
                    "background-color": "rgba(0, 164, 228, 0.3)", // Light blue color when disabled
                    "cursor": "not-allowed"
                });
            }

            function enableSubmitButton() {
                $("#form input[type='submit']").prop('disabled', false).css({
                    "background-color": "rgba(0, 150, 228)", // Original color when enabled
                    "cursor": "pointer"
                });
            }

            function validateForm() {
                var isValid = true;

                // Reset error messages
                $(".error-message").hide();

                // Validate required fields
                $("#form input[type='text'], #form input[type='email'], #form textarea").each(function() {
                    var id = $(this).attr('id');

                    // Skip validation for the Company field
                    if (id === 'company') {
                        return;
                    }
                    if ($(this).val().trim() === '') {
                        isValid = false;
                        if ($(this).data('touched')) {
                            $("#" + id + "Error").text("This field is required.").show();
                        }
                    } else {
                        $("#" + id + "Error").hide();
                    }
                });

                // Validate Company field separately
                var companyField = $("#form input#company");
                if (companyField.data('touched') && companyField.val().trim() === '') {
                    $("#" + companyField.attr('id') + "Error").hide(); // Ensure no error is shown for Company field if empty
                }

                // Validate first name
                var firstName = $("#form input[name='firstName']").val();
                if (firstName && firstName.trim().length < 2) {
                    isValid = false;
                    if ($("#firstName").data('touched')) {
                        $("#firstNameError").text("First name must be at least 2 characters.").show();
                    }
                }

                // Validate last name
                var lastName = $("#form input[name='lastName']").val();
                if (lastName && lastName.trim().length < 2) {
                    isValid = false;
                    if ($("#lastName").data('touched')) {
                        $("#lastNameError").text("Last name must be at least 2 characters.").show();
                    }
                }

                // Validate email
                var email = $("#form input[name='email']").val();
                var emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                if (email && !emailPattern.test(email)) {
                    isValid = false;
                    if ($("#email").data('touched')) {
                        $("#emailError").text("Please enter a valid email address.").show();
                    }
                }

                // Validate website
                var website = $("#form input[name='website']").val();
                var websitePattern = /^(http[s]?:\/\/)?([a-zA-Z0-9-]+\.)+[a-zA-Z]{2,6}$/;
                if (website && !websitePattern.test(website)) {
                    isValid = false;
                    if ($("#website").data('touched')) {
                        $("#websiteError").text("Please enter a valid website URL.").show();
                    }
                }

                // Enable or disable submit button based on validity
                if (isValid) {
                    enableSubmitButton();
                } else {
                    disableSubmitButton();
                }
            }


           function initialCheck() {
                var allFilled = true;

                // Check all text, email, and website fields except the company field
                $("#form input[type='text'], #form input[type='email'], #form input[name='website']").each(function() {
                    if ($(this).attr('id') !== 'company' && $(this).val().trim() === '') {
                        allFilled = false;
                    }
                });

                if (allFilled) {
                    validateForm(); // Validate form fields
                } else {
                    disableSubmitButton(); // Disable the button if not all required fields are filled
                }
            }

            // Event handlers for form validation and submit button state
            $("#form input").on("focus blur input", function() {
                $(this).data('touched', true); // Mark field as interacted
                validateForm(); // Validate form on focus, blur, and input
            });

            $("#form textarea").on("focus blur input", function() {
                $(this).data('touched', true); // Mark field as interacted
                validateForm(); // Validate form on focus, blur, and input
            });

            $("#form").on("submit", function(event) {
                validateForm(); // Validate form on submit
                if ($("#form input[type='submit']").prop('disabled')) {
                    event.preventDefault(); // Prevent form submission if invalid
                }
            });

            function getCookieValue(name) {
                const cookies = document.cookie.split("; "); // Split cookies by "; "
                
                for (let cookie of cookies) {
                    let [key, value] = cookie.split("="); // Split each cookie into key and value
                    if (key === name) {
                        return decodeURIComponent(value); // Decode and return value
                    }
                }
                return null; // Return null if cookie not found
            }

            // Populate display fields and hidden inputs when modal opens
            function populateUserInfo() {
                const firstName = getCookieValue("first_name") || "";
                const lastName = getCookieValue("last_name") || "";
                const company = getCookieValue("company") || "";
                const email = getCookieValue("email") || "";

                $("#displayFirstName").text(firstName);
                $("#displayLastName").text(lastName);
                $("#displayCompany").text(company);
                $("#displayEmail").text(email);

                // Set values for existing hidden fields
                $("#email").val(email);
                $("#company").val(company);
                $("#firstName").val(firstName);
                $("#lastName").val(lastName);
            }

            $("input[name='licenceCategory']").on("click", function() {
                $("#categoryFormModal").hide();
                $("#contactModal").hide();
                var selectedCategory = $(this).val();
                var categoryName = $(this).attr('data-category');
                if (selectedCategory == "other" || categoryName) {
                    $("#selected_cat").text(selectedCategory == "other" ? "Other" :categoryName);
                    $("#selectedCat").val(selectedCategory == "other" ? "Other" :categoryName);
                    //- populateUserInfo(); // Populate user info from cookies
                    $("#contactModal").show();
                } else {

                    //- Old code
                    //- $("#categoryFormModal").show();
                    //- $("#form input[name='licenceCategory']").val(selectedCategory);
                    //- initialCheck(); // Revalidate form when modal opens
     
                    const trackId = $("*[data-track]").attr("data-track");
        var form = $('<form>', {
            id: 'dynamicForm',
            action: "/trolley/add/" + trackId + "/commercial",
            method: "POST"
        });
        form.append($('<input>', {
            type: 'hidden',
            name: 'licenceCategory',
            value: selectedCategory
        }));
        form.append($('<input>', {
            type: 'hidden',
            name: 'firstName',
            value: getCookieValue("first_name")
        }));
        form.append($('<input>', {
            type: 'hidden',
            name: 'lastName',
            value: getCookieValue("last_name")
        }));
        form.append($('<input>', {
            type: 'hidden',
            name: 'email',
            value: getCookieValue("email")
        }));
         form.append($('<input>', {
            type: 'hidden',
            name: 'categoryName',
            value: categoryName
        }));
        form.append($('<input>', {
            type: 'hidden',
            name: 'company',
            value: getCookieValue("company")
        }));
        $("body").append(form);
        form.submit();

        
                }
            });

            $(".modal .close").on("click", function() {
                $(".modal").hide();
                initialCheck(); // Revalidate form when modal closes
            });

            $(window).on("click", function(event) {
                if ($(event.target).hasClass("modal")) {
                    $(".modal").hide();
                    initialCheck(); // Revalidate form when modal closes
                }
            });

            // Initially check all fields and disable/enable the submit button
            initialCheck();
        });

